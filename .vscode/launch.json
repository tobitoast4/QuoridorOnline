{
    // Use these configurations when working with Visual Studio Code.
    // First configuration allows to debug a single file (also library 
    // debugging), 
    // second configuration can be used to run the server from within 
    // the 'Run and debug' tab in VS Code.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "RunPython",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Runserver",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "console": "integratedTerminal",
            "env": {
                "DEBUG_LEVEL": "2"
            },
            "args": ["runserver"],
            "django": true,
            "justMyCode": false
        },
        {
            "name": "Django Tests",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            // "args": ["test"],
            "args": ["test", "web.testing.uitests.test_pdf_build.TestBuildUI.test_create_final_pdf"],
            // "args": ["test", "web.testing.uitests.test_project.TestProjectUI.test_insert_image"],
            "django": true,
            "justMyCode": false
        }
    ]
}